# Ligação à base de dados Postgres (Neon).
# No Vercel: Storage -> Create Database -> Postgres (Neon) preenche isto automaticamente.
# Em local: corre `vercel env pull .env.local` depois de ligares a base de dados,
# ou cola aqui a connection string que o Neon te dá.
DATABASE_URL=postgres://usuario:password@ep-exemplo.neon.tech/neondb?sslmode=require

# Senha simples para veres a lista de confirmações em /admin
ADMIN_PASSWORD=escolhe-uma-senha-forte
